# ============================================================
# CloudSentinel – config.env.example
# Copy to config.env and fill in your actual values.
# NEVER commit config.env to Git.
# ============================================================

# ---- PostgreSQL Database --------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudsentinel
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=prefer

# ---- Cloud Instance Identity ----------------------------
INSTANCE_ID=i-0abc1234def567890

# ---- Collection & Detection Settings --------------------
COLLECT_INTERVAL=30       # seconds between metric collections
DETECT_INTERVAL=30        # seconds between detection cycles
WINDOW_SIZE=60            # sliding window size (= 30 min at 30s interval)

# ---- Alert / SMTP Settings ------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_FROM=your_email@gmail.com
ALERT_TO=admin1@example.com,admin2@example.com
ALERT_COOLDOWN_SECS=300   # 5-minute cooldown between repeat alerts
